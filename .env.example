# LLM Configuration (OpenAI-compatible API)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Optional cheaper model for batch triage scoring (defaults to LLM_MODEL)
LLM_TRIAGE_MODEL=gpt-4o-mini

# Daily email digest (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-password
# Set to true for implicit TLS (port 465)
SMTP_SECURE=false
MAIL_FROM=Research Scout <you@example.com>

# Authentication whitelist: comma-separated email:password pairs.
# Leave empty to disable authentication (local use only).
AUTH_USERS=you@example.com:change-me
# Required when AUTH_USERS is set. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Public URL of the deployed app (used for links in digest emails and secure cookies)
APP_BASE_URL=http://localhost:3000

# Optional: override the SQLite database location (used by Docker)
# DB_PATH=/data/research-scout.db
